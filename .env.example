# ─── PRODUCTION SECURITY REQUIREMENTS ───────────────────────────────────────
# APP_DEBUG must be false in production.
# SESSION_SECURE_COOKIE must be true when HTTPS is active.
# Never commit real secrets to version control.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME=Laravel
# PRODUCTION: set APP_ENV=production
APP_ENV=local
APP_KEY=
# PRODUCTION: set APP_DEBUG=false
APP_DEBUG=false
# PRODUCTION: set APP_URL to your HTTPS domain, e.g. https://euisis.addisababa.gov.et
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# PRODUCTION: use LOG_STACK=daily to get rotating log files
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# PRODUCTION: set LOG_LEVEL=warning or LOG_LEVEL=error to avoid verbose logs in production
LOG_LEVEL=warning

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# PRODUCTION: must be true — encrypts session payload at rest
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# PRODUCTION: must be true when HTTPS is active — prevents cookie over HTTP
SESSION_SECURE_COOKIE=true
# Cookie is HTTP-only by default; keep true so JS cannot read the session cookie
SESSION_HTTP_ONLY=true
# SameSite policy for the session cookie: lax|strict|none
SESSION_SAME_SITE=strict

# ─── Sanctum ────────────────────────────────────────────────────────────────
# Token expiration in minutes. 480 = 8 hours. 43200 = 30 days (too long for production).
# PRODUCTION: use 480 (8 hours) or 60 (1 hour) for stricter token rotation.
SANCTUM_TOKEN_EXPIRATION_MINUTES=480

# ─── CORS ───────────────────────────────────────────────────────────────────
# PRODUCTION: set to your exact HTTPS domain — never use * in production
# CORS_ALLOWED_ORIGINS=https://euisis.addisababa.gov.et

# ─── Sanctum token prefix ────────────────────────────────────────────────────
# Prefix helps secret-scanning tools (GitHub, GitLab) detect accidentally committed tokens
SANCTUM_TOKEN_PREFIX=euisis_

# ─── Auth / Registration ────────────────────────────────────────────────────
# Public self-service registration is OFF by default. Admins create accounts.
REGISTRATION_ENABLED=false

# ─── MFA ────────────────────────────────────────────────────────────────────
# Roles (comma-separated, exact role names) that MUST enrol TOTP MFA.
# PRODUCTION: expand to include all roles with access to employee PII.
MFA_REQUIRED_ROLES="Super Admin,City Admin,HR Manager,Cafeteria Admin,Security Officer"

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
